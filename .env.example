# For local development (SQLite - no setup needed)
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# For production (PostgreSQL on Neon/Supabase)
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Admin passcode — REQUIRED in production (login is disabled without it)
PASSCODE="choose-a-strong-passcode"

# Secret for signing the admin auth cookie — set a long random string in production
AUTH_SECRET="generate-a-long-random-string"
