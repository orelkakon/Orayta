generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citation {
  id          String             @id @default(cuid())
  content     String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  locations   CitationLocation[]
  quizResults QuizResult[]
}

model CitationLocation {
  id         String   @id @default(cuid())
  citationId String
  masechet   String
  seder      String
  daf        String
  amud       String?
  citation   Citation @relation(fields: [citationId], references: [id], onDelete: Cascade)

  @@index([masechet])
  @@index([citationId])
}

model Rabbi {
  id         String   @id @default(cuid())
  name       String
  fullName   String?
  sortYear   Int
  datePeriod String
  isAlive    Boolean  @default(false)
  bio        String
  category   String
  createdAt  DateTime @default(now())
  deathDate  String?
  imageUrl   String?

  @@index([category])
  @@index([sortYear])
}

model Gematria {
  id        String   @id @default(cuid())
  word      String
  value     Int
  createdAt DateTime @default(now())

  @@index([value])
}

model Book {
  id        String   @id @default(cuid())
  title     String
  author    String
  createdAt DateTime @default(now())
  rabbiId   String?

  @@index([author])
  @@index([rabbiId])
}

model Chidush {
  id        String   @id @default(cuid())
  text      String
  source    String?
  author    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String?
  message   String
  rating    Int?
  createdAt DateTime @default(now())
}

model Dedication {
  id        String   @id @default(cuid())
  type      String
  name      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model PageVisit {
  id     String   @id @default(cuid())
  ipHash String   @unique
  seenAt DateTime @default(now())

  @@index([ipHash])
}

model GlobalCounter {
  key   String @id
  value Int    @default(0)
}

model FeedLike {
  id       String @id @default(cuid())
  itemType String
  itemId   String
  reaction String @default("heart")
  likes    Int    @default(0)

  @@unique([itemType, itemId, reaction])
  @@index([itemType])
  @@index([reaction])
}

model QuizResult {
  id         String   @id @default(cuid())
  citationId String
  answeredAt DateTime @default(now())
  score      Float
  citation   Citation @relation(fields: [citationId], references: [id], onDelete: Cascade)

  @@index([citationId])
}

model SikumBook {
  id        String       @id @default(cuid())
  name      String
  author    String?
  icon      String?      @default("📒")
  createdAt DateTime     @default(now())
  entries   SikumEntry[]

  @@index([name])
}

model SikumEntry {
  id        String    @id @default(cuid())
  bookId    String
  book      SikumBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  title     String?
  text      String
  date      DateTime  @default(now())
  dateEnd   DateTime?
  location  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([bookId])
  @@index([date])
}
